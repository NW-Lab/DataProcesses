<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DataProcesses.Desktop.ViewModels"
        xmlns:views="using:DataProcesses.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="800"
        x:Class="DataProcesses.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="600"
        Title="DataProcesses">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#172033" Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0"
                           Text="DataProcesses"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <TextBlock Grid.Column="1"
                           Margin="24,0"
                           Text="{Binding ProjectTitle}"
                           Foreground="#B8C2D8"
                           VerticalAlignment="Center" />
                <Button Grid.Column="2" Content="Preferences" />
            </Grid>
        </Border>

        <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0" Background="#0F1B2D" Padding="12,8">
                <Grid ColumnDefinitions="Auto,Auto,20,Auto,Auto,Auto,*,Auto" ColumnSpacing="8">
                    <Button Grid.Column="0" Content="Flow" Command="{Binding ShowFlowViewCommand}" />
                    <Button Grid.Column="1" Content="Dashboard" Command="{Binding ShowDashboardViewCommand}" />
                <Button Grid.Column="3"
                    Width="38"
                    Height="30"
                    Content="▶"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Background="{Binding RunButtonBackground}"
                    Command="{Binding RunCommand}"
                    ToolTip.Tip="Run" />
                <Button Grid.Column="4"
                    Width="38"
                    Height="30"
                    Content="▷"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Background="{Binding DebugButtonBackground}"
                    Command="{Binding DebugRunCommand}"
                    ToolTip.Tip="Run (Debug)" />
                <Button Grid.Column="5"
                    Width="38"
                    Height="30"
                    Content="■"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Background="{Binding StopButtonBackground}"
                    Command="{Binding StopCommand}"
                    ToolTip.Tip="Stop (Edit mode)" />
                    <TextBlock Grid.Column="7"
                               Text="{Binding CurrentModeLabel}"
                               Foreground="White"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <ContentControl IsVisible="{Binding IsFlowViewSelected}" Content="{Binding FlowEditor}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:FlowEditorView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
                <ContentControl IsVisible="{Binding IsDashboardViewSelected}" Content="{Binding Dashboard}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:DashboardView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
